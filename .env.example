# Jira 연동 (캘린더 사이트처럼 이 프로젝트에서 바로 사용)
# 이 파일을 복사해서 .env 로 저장한 뒤 값을 채우세요.

# Jira 사이트 URL (예: https://회사도메인.atlassian.net)
JIRA_BASE_URL=
# 또는
# ATLASSIAN_URL=

# Jira 로그인 이메일
JIRA_EMAIL=

# Jira API 토큰 ( https://id.atlassian.com/manage-profile/security/api-tokens 에서 발급 )
JIRA_API_TOKEN=
# 또는
# ATLASSIAN_API_TOKEN=

# API 서버 포트 (기본 3001, 프론트가 이 포트로 프록시함)
# PORT=3001
