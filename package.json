{
  "name": "bug-dashboard-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npx vite",
    "api": "node server/index.js",
    "dev:all": "npx concurrently -n api,vite \"npm run api\" \"npm run dev\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "preview:local": "npm run build && npx concurrently -n api,preview \"npm run api\" \"vite preview\""
  },
  "dependencies": {
    "chart.js": "^4.4.1",
    "dotenv": "^16.3.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
